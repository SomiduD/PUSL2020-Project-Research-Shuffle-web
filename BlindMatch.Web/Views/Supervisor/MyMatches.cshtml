@model IEnumerable<BlindMatch.Web.Models.ProjectProposal>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "My Matches";
}

<div class="container mt-4">
    <h2>My Confirmed Matches</h2>
    <p class="text-success fw-bold">The blind phase is over. Here are your official project allocations and student details.</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            You haven't matched with any projects yet. Check the Dashboard to find available proposals!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                var student = await UserManager.FindByIdAsync(item.StudentId);
                var studentContact = student?.Email ?? "Details Unavailable";

                <div class="col-md-6 mb-4">
                    <div class="card border-success shadow-sm h-100">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">@item.Title</h5>
                        </div>
                        <div class="card-body">

                            <div class="d-flex align-items-center mb-4 p-3 bg-light border rounded">
                                <img src="https://ui-avatars.com/api/?name=Student&background=0D8ABC&color=fff&rounded=true" alt="Student Photo" width="50" height="50" class="me-3 shadow-sm">
                                <div>
                                    <h6 class="mb-0 text-success fw-bold">Identity Revealed!</h6>
                                    <small class="text-muted"><strong>Contact:</strong> @studentContact</small>
                                </div>
                            </div>

                            <p class="mt-3"><strong>Abstract:</strong></p>
                            <p class="card-text">@item.Abstract</p>

                            <p><strong>Tech Stack:</strong> <span class="badge bg-info text-dark">@item.TechnicalStack</span></p>
                        </div>
                        <div class="card-footer bg-white">
                            <button class="btn btn-outline-success w-100" disabled>Match Officially Confirmed</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>