@model IEnumerable<BlindMatch.Web.Models.ProjectProposal>

@{
    ViewData["Title"] = "My Matches";
}

<div class="container mt-4">
    <h2>My Confirmed Matches</h2>
    <p class="text-success fw-bold">The blind phase is over. These are your official project allocations.</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            You haven't matched with any projects yet. Check the Dashboard to find available proposals!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-success shadow-sm h-100">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">@item.Title</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="text-dark">Status: <span class="badge bg-success">@item.Status</span></h6>
                            <p class="mt-3"><strong>Abstract:</strong></p>
                            <p class="card-text">@item.Abstract</p>

                            <p><strong>Tech Stack:</strong> <span class="badge bg-info text-dark">@item.TechnicalStack</span></p>
                        </div>
                        <div class="card-footer bg-white">
                            <button class="btn btn-outline-success w-100" disabled>Match Officially Confirmed</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>