@model IEnumerable<BlindMatch.Web.Models.ProjectProposal>

@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="container mt-4">
    <h2>Available Project Proposals</h2>
    <p class="text-muted">Review proposals blindly. Student identities are hidden until a match is confirmed.</p>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            There are currently no unmatched proposals available.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">@item.Title</h5>
                        </div>
                        <div class="card-body">
                            <h6 class="text-muted">Identity: <span class="badge bg-secondary">Hidden (Blind Match)</span></h6>
                            <p class="mt-3"><strong>Abstract:</strong></p>
                            <p class="card-text">@item.Abstract</p>

                            <p><strong>Tech Stack:</strong> <span class="badge bg-info text-dark">@item.TechnicalStack</span></p>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <form asp-action="ConfirmMatch" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-primary w-100">Confirm Match & Reveal Student</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>