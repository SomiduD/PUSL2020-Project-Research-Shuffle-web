@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5 mb-5">
    <h1 class="display-4 fw-bold">Welcome to BlindMatch</h1>
    <p class="lead text-muted">The unbiased project allocation system for NSBM Undergraduates.</p>
    <hr class="w-50 mx-auto mt-4 mb-4" />
</div>

<div class="container">
    <div class="row justify-content-center">
        
        <div class="col-md-5 d-flex flex-column justify-content-center text-center">
            @if (User.Identity.IsAuthenticated)
            {
                <h3 class="fw-bold text-primary mb-4">Live System Analytics</h3>
                <div class="row text-center mb-4">
                    <div class="col-4">
                        <h2 class="fw-bold">@ViewBag.Total</h2>
                        <span class="text-muted small">Total Submissions</span>
                    </div>
                    <div class="col-4">
                        <h2 class="fw-bold text-warning">@ViewBag.Pending</h2>
                        <span class="text-muted small">Pending Review</span>
                    </div>
                    <div class="col-4">
                        <h2 class="fw-bold text-success">@ViewBag.Matched</h2>
                        <span class="text-muted small">Matches Confirmed</span>
                    </div>
                </div>
                <p class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> You are securely logged in.</p>
            }
            else
            {
                <h3 class="fw-bold text-primary mb-4">Secure Allocation</h3>
                <p class="text-muted px-4">
                    BlindMatch ensures that all student project proposals are evaluated strictly on technical merit. Identities are completely hidden from supervisors until a project match is officially confirmed.
                </p>
                <div class="mt-3">
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-4 shadow-sm">Log In to Continue</a>
                </div>
            }
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-3 h-100 d-flex flex-column justify-content-center">
                
                @if (User.Identity.IsAuthenticated)
                {
                    if (ViewBag.Total == 0)
                    {
                        <div class="text-center p-5 text-muted">
                            <em>No projects submitted yet. The chart will appear here automatically.</em>
                        </div>
                    }
                    else
                    {
                        <canvas id="allocationChart" width="400" height="400"></canvas>
                    }
                }
                else
                {
                    <div class="text-center p-5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="#6c757d" class="bi bi-lock-fill mb-3" viewBox="0 0 16 16">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                        </svg>
                        <h4 class="fw-bold text-dark">Analytics Locked</h4>
                        <p class="text-muted small mb-0">System metrics are restricted to authenticated university personnel. Please log in to view live data.</p>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        if (document.getElementById('allocationChart')) {
            var ctx = document.getElementById('allocationChart').getContext('2d');
            
            var allocationChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Pending Review', 'Matches Confirmed'],
                    datasets: [{
                        data: [@ViewBag.Pending, @ViewBag.Matched],
                        backgroundColor: ['#ffc107', '#198754'],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    </script>
}